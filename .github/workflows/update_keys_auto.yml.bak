name: Auto Update

on:
  schedule:
    # 毎日の 日本時間 夜3時 (UTC 18:00)
    - cron: '0 18 * * *'
  workflow_dispatch:

jobs:
  update-keys:
    runs-on: ubuntu-latest
    timeout-minutes: 360
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.x'

      - name: Install dependencies
        run: pip install requests

      - name: Fetch key and generate files
        env:
          GITHUB_EVENT_NAME: ${{ github.event_name }}
        run: |
          python -c "
          import requests
          import json
          import urllib.parse
          import os
          import time
          import random
          from requests.adapters import HTTPAdapter
          from urllib3.util.retry import Retry

          # ---------------------------------------------------------
          # 1. 時間調整 (待機なし)
          # ---------------------------------------------------------
          print('Skipping long sleep as requested. Starting immediately.')

          # ---------------------------------------------------------
          # 2. ブラウザ偽装設定
          # ---------------------------------------------------------
          is_ipad = random.choice([True, False])

          if is_ipad:
              # iPad Safari
              user_agent = 'Mozilla/5.0 (iPad; CPU OS 17_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Mobile/15E148 Safari/604.1'
              headers = {
                  'User-Agent': user_agent,
                  'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
                  'Accept-Language': 'ja-JP,ja;q=0.9,en-US;q=0.8,en;q=0.7',
                  'Accept-Encoding': 'gzip, deflate, br',
                  'Referer': 'https://create.kahoot.it/',
                  'Sec-Fetch-Dest': 'document',
                  'Sec-Fetch-Mode': 'navigate',
                  'Sec-Fetch-Site': 'none'
              }
              print('Acting as: iPad Safari')
          else:
              # Windows Chrome
              user_agent = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
              headers = {
                  'User-Agent': user_agent,
                  'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
                  'Accept-Language': 'ja,en-US;q=0.9,en;q=0.8',
                  'Accept-Encoding': 'gzip, deflate, br',
                  'Referer': 'https://create.kahoot.it/',
                  'Sec-Ch-Ua': '\"Not_A Brand\";v=\"8\", \"Chromium\";v=\"120\", \"Google Chrome\";v=\"120\"',
                  'Sec-Ch-Ua-Mobile': '?0',
                  'Sec-Ch-Ua-Platform': '\"Windows\"',
                  'Sec-Fetch-Dest': 'document',
                  'Sec-Fetch-Mode': 'navigate',
                  'Sec-Fetch-Site': 'none',
                  'Upgrade-Insecure-Requests': '1'
              }
              print('Acting as: Windows Chrome')

          session = requests.Session()
          session.headers.update(headers)

          # ---------------------------------------------------------
          # 3. キー取得処理
          # ---------------------------------------------------------
          
          # 関数: 失敗しても1回だけリトライする仕組み
          def fetch_with_retry(url, description, is_json=False):
              max_retries = 2
              for attempt in range(1, max_retries + 1):
                  try:
                      print(f'Fetching {description}... (Attempt {attempt})')
                      resp = session.get(url, timeout=10)
                      resp.raise_for_status()
                      return resp
                  except Exception as e:
                      print(f'Error fetching {description}: {e}')
                      if attempt < max_retries:
                          wait_retry = random.randint(20, 40)
                          print(f'Retrying in {wait_retry} seconds...')
                          time.sleep(wait_retry)
                      else:
                          raise e

          try:
              # Step A: ホームページアクセス
              fetch_with_retry('https://create.kahoot.it/', 'Home Page')
              time.sleep(random.uniform(2, 5))

              # Step B: favicon取得 (ブラウザっぽく振る舞う)
              try:
                  img_headers = {'Accept': 'image/webp,image/apng,image/*,*/*;q=0.8', 'Sec-Fetch-Dest': 'image'}
                  session.get('https://create.kahoot.it/favicon.ico', headers=img_headers, timeout=5)
                  print('Fetched favicon (acting like a real browser).')
              except:
                  pass

              time.sleep(random.uniform(3, 8))

              # Step C: 本命のキー取得
              api_url = 'https://apis.kahoot.it/media-api/youtube/key'
              session.headers.update({'Sec-Fetch-Dest': 'empty', 'Sec-Fetch-Mode': 'cors', 'Sec-Fetch-Site': 'same-site'})
              
              response = fetch_with_retry(api_url, 'API Key', is_json=True)
              
              data = response.json()
              key_value = data['key']
              print('Key fetched successfully!')

              # -----------------------------------------------------
              # 4. ファイル生成と保存
              # -----------------------------------------------------
              # key1, key2用のベースパラメータ (controls=1, fs=1)
              base_params_1_2 = '?autoplay=1&amp;mute=0&amp;controls=1&amp;start=0&amp;origin=https%3A%2F%2Fcreate.kahoot.it&amp;playsinline=1&amp;showinfo=0&amp;rel=0&amp;iv_load_policy=3&amp;modestbranding=1&amp;fs=1&amp;cc_load_policy=0&amp;enablejsapi=1&amp;widgetid=1&amp;forigin=https%3A%2F%2Fcreate.kahoot.it%2Flearner%2Fcb8cb5ae-d835-4c4a-bc2d-9cc78519d646%2Fcourse%2F6fba06e3-1f76-47a8-9a4a-53c53eb86286%2F0&amp;aoriginsup=1&amp;vf=6'

              # key3用の新しいベースパラメータ (controls=0, fs=0)
              base_params_3 = '?autoplay=1&amp;mute=0&amp;controls=0&amp;start=0&amp;origin=https%3A%2F%2Fcreate.kahoot.it&amp;playsinline=1&amp;showinfo=0&amp;rel=0&amp;iv_load_policy=3&amp;modestbranding=1&amp;fs=0&amp;cc_load_policy=0&amp;enablejsapi=1&amp;widgetid=1&amp;forigin=https%3A%2F%2Fcreate.kahoot.it%2Flearner%2Fcb8cb5ae-d835-4c4a-bc2d-9cc78519d646%2Fcourse%2F6fba06e3-1f76-47a8-9a4a-53c53eb86286%2F0&amp;aoriginsup=1&amp;vf=6'

              # Config作成関数
              def make_config(base_url, k, hide):
                  cfg = {'enc': k, 'hideTitle': hide}
                  json_str = json.dumps(cfg, separators=(',', ':'))
                  return f'{base_url}&amp;embed_config={urllib.parse.quote(json_str)}'

              final_str_1 = make_config(base_params_1_2, key_value, False)
              final_str_2 = make_config(base_params_1_2, key_value, True)
              
              # key3.json の内容を作成 (hideTitle: true で生成)
              final_str_3 = make_config(base_params_3, key_value, True)

              output_dir = 'keys'
              os.makedirs(output_dir, exist_ok=True)

              with open(os.path.join(output_dir, 'key1.json'), 'w') as f:
                  json.dump({'result': final_str_1}, f, indent=2)

              with open(os.path.join(output_dir, 'key2.json'), 'w') as f:
                  json.dump({'result': final_str_2}, f, indent=2)

              with open(os.path.join(output_dir, 'key3.json'), 'w') as f:
                  json.dump({'result': final_str_3}, f, indent=2)

              with open(os.path.join(output_dir, 'key.json'), 'w') as f:
                  json.dump({'key': key_value}, f, indent=2)

              print('Files saved.')

          except Exception as e:
              print(f'Critical Error: {e}')
              exit(1)
          "

      - name: Commit and push changes
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          
          # key3.json もコミット対象に追加
          git add keys/key1.json keys/key2.json keys/key3.json keys/key.json
          
          if git diff --staged --quiet; then
            echo "No changes to commit."
          else
            git commit -m "Update Kahoot keys [skip ci]"
            git push
          fi
